# ===================================
# Frontend Environment Variables
# Copy this to .env for local dev
# ===================================

# API base URL — local dev → http://localhost:5001/api, prod → deployed backend URL
VITE_API_URL=http://localhost:5001/api

# Google OAuth Client ID (optional — leave blank to disable Google login)
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
